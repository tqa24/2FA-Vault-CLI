{
  "name": "2favault-cli",
  "version": "0.1.0",
  "description": "Command-line client for 2FA-Vault. Manage your two-factor accounts from the terminal.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "2fav": "./dist/2fav"
  },
  "scripts": {
    "build": "bun build src/cli.ts --compile --outfile dist/2fav",
    "build:linux-x64": "bun build src/cli.ts --compile --target=bun-linux-x64 --outfile dist/2fav-linux-x64",
    "build:linux-arm64": "bun build src/cli.ts --compile --target=bun-linux-arm64 --outfile dist/2fav-linux-arm64",
    "build:darwin-x64": "bun build src/cli.ts --compile --target=bun-darwin-x64 --outfile dist/2fav-darwin-x64",
    "build:darwin-arm64": "bun build src/cli.ts --compile --target=bun-darwin-arm64 --outfile dist/2fav-darwin-arm64",
    "build:win-x64": "bun build src/cli.ts --compile --target=bun-windows-x64 --outfile dist/2fav-win-x64.exe",
    "dev": "bun run src/cli.ts"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "files": [
    "src",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "2fa",
    "totp",
    "otp",
    "two-factor",
    "authentication",
    "cli",
    "2fauth",
    "2favault"
  ]
}
